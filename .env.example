# Sleep-BCI Docker Environment Configuration
# Copy this file to .env and modify as needed
# .env is gitignored and will be loaded by docker-compose

# API Server Configuration
# Port on which the API server will listen
PORT=8000

# Host address for the API server
# 0.0.0.0 makes it accessible from outside the container
HOST=0.0.0.0

# Logging Configuration
# Options: debug, info, warning, error, critical
LOG_LEVEL=info

# Redis Configuration
# Job state is stored in Redis when this is set.
# If unset, an in-memory dict is used (jobs are lost on server restart).
# Docker: set automatically via docker-compose. Local dev: leave unset or run Redis locally.
REDIS_URL=redis://localhost:6379
